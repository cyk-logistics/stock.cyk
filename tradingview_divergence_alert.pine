//@version=5
indicator("SET ปันผล — RSI Bull & Bear Divergence + Entry", shorttitle="DIV Entry")

// ===== Inputs =====
rsiLen     = input.int(14, "RSI Length")
lbL        = input.int(5,  "Pivot Left")
lbR        = input.int(5,  "Pivot Right")
rangeLower = input.int(5,  "Min bars between pivots")
rangeUpper = input.int(60, "Max bars between pivots")
osLevel    = input.int(40, "Oversold filter (RSI <=)")

osc = ta.rsi(close, rsiLen)

hline(70, "Overbought", color=color.red)
hline(30, "Oversold",   color=color.green)
plot(osc, "RSI", color=color.new(color.blue, 0))
bgcolor(osc < 30 ? color.new(color.green, 90) : osc > 70 ? color.new(color.red, 90) : na)

inRange(cond) =>
    bars = ta.barssince(cond)
    rangeLower <= bars and bars <= rangeUpper

// ===== Bullish Divergence (กระทิง: ราคา Lower Low, RSI Higher Low) =====
plFound = not na(ta.pivotlow(osc, lbL, lbR))
oscHL   = osc[lbR] > ta.valuewhen(plFound, osc[lbR], 1) and inRange(plFound[1])
priceLL = low[lbR] < ta.valuewhen(plFound, low[lbR], 1)
bullDiv = plFound and priceLL and oscHL
buy     = bullDiv and osc[lbR] <= osLevel

// ===== Bearish Divergence (หมี: ราคา Higher High, RSI Lower High) =====
phFound = not na(ta.pivothigh(osc, lbL, lbR))
oscLH   = osc[lbR] < ta.valuewhen(phFound, osc[lbR], 1) and inRange(phFound[1])
priceHH = high[lbR] > ta.valuewhen(phFound, high[lbR], 1)
bearDiv = phFound and priceHH and oscLH

// ===== Plot บนแพเนล RSI =====
plot(plFound ? osc[lbR] : na, "Bull line", offset=-lbR, color = bullDiv ? color.green : color.new(color.white, 100), linewidth=2)
plot(phFound ? osc[lbR] : na, "Bear line", offset=-lbR, color = bearDiv ? color.red   : color.new(color.white, 100), linewidth=2)
plotshape(bullDiv, "Bull Div", style=shape.labelup,   location=location.absolute, offset=-lbR, text="BULL", color=color.green, textcolor=color.white, size=size.tiny)
plotshape(bearDiv, "Bear Div", style=shape.labeldown, location=location.absolute, offset=-lbR, text="BEAR", color=color.red,   textcolor=color.white, size=size.tiny)
plotshape(buy, "BUY", style=shape.triangleup, location=location.bottom, text="BUY", color=color.lime, size=size.tiny)

plot(buy     ? 1 : 0, "Buy Signal",  display=display.data_window)
plot(bearDiv ? 1 : 0, "Bear Signal", display=display.data_window)

// ===== Discord Alerts: ยิง JSON ตรงเข้า webhook =====
buyMsg = '{"content": "🟢 **BUY** ' + syminfo.ticker +
      ' | ราคา ' + str.tostring(close, format.mintick) +
      ' | RSI ' + str.tostring(osc, '#.0') +
      ' | Bullish Divergence | TF ' + timeframe.period + '"}'
if buy
    alert(buyMsg, alert.freq_once_per_bar_close)

bearMsg = '{"content": "🔴 **BEAR** ' + syminfo.ticker +
      ' | ราคา ' + str.tostring(close, format.mintick) +
      ' | RSI ' + str.tostring(osc, '#.0') +
      ' | Bearish Divergence (ระวังกลับหัว) | TF ' + timeframe.period + '"}'
if bearDiv
    alert(bearMsg, alert.freq_once_per_bar_close)

// ===== ทางเลือก: ตั้ง alert แบบเลือกเงื่อนไขเอง =====
alertcondition(bullDiv, "Bullish Divergence", "RSI Bullish Divergence")
alertcondition(bearDiv, "Bearish Divergence", "RSI Bearish Divergence")
alertcondition(buy,     "Buy Signal",         "สัญญาณเข้าซื้อ (divergence + oversold)")
